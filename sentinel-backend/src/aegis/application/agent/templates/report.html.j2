<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Aegis AI Security Report</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            color: #333;
            line-height: 1.6;
            margin: 0;
            padding: 40px;
            background-color: #f9fafb;
        }
        .container {
            max-width: 900px;
            margin: 0 auto;
            background: #fff;
            padding: 40px;
            border-radius: 8px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }
        h1, h2, h3, h4 { color: #111; }
        .header {
            border-bottom: 2px solid #eaeaea;
            padding-bottom: 20px;
            margin-bottom: 30px;
        }
        .header h1 {
            margin: 0 0 10px 0;
            font-size: 28px;
        }
        .meta {
            color: #666;
            font-size: 14px;
            display: flex;
            justify-content: space-between;
        }
        .summary-cards {
            display: flex;
            gap: 20px;
            margin-bottom: 40px;
        }
        .card {
            background: #f3f4f6;
            padding: 20px;
            border-radius: 6px;
            flex: 1;
            text-align: center;
        }
        .card.threat { background: #fee2e2; border: 1px solid #fecaca; }
        .card h3 { margin: 0 0 10px 0; font-size: 14px; color: #4b5563; text-transform: uppercase; }
        .card .value { font-size: 24px; font-weight: bold; color: #111; }
        
        .finding {
            border: 1px solid #e5e7eb;
            border-radius: 6px;
            margin-bottom: 20px;
            overflow: hidden;
        }
        .finding-header {
            background: #f9fafb;
            padding: 15px 20px;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .finding-header h3 { margin: 0; font-size: 16px; }
        .badge {
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: bold;
            color: white;
            text-transform: uppercase;
        }
        .badge.critical { background: #ef4444; }
        .badge.high { background: #f97316; }
        .badge.medium { background: #eab308; }
        .badge.low { background: #22c55e; }
        
        .finding-body { padding: 20px; }
        .finding-body p { margin-top: 0; font-size: 14px; }
        .code-snippet {
            background: #1e1e1e;
            color: #d4d4d4;
            padding: 15px;
            border-radius: 6px;
            font-family: monospace;
            font-size: 12px;
            overflow-x: auto;
            margin-bottom: 15px;
        }
        .remediation {
            background: #f0fdf4;
            border-left: 4px solid #22c55e;
            padding: 15px;
            border-radius: 0 6px 6px 0;
            font-size: 14px;
            margin-top: 15px;
        }
        
        .timeline {
            border-left: 2px solid #e5e7eb;
            padding-left: 20px;
            margin-top: 30px;
        }
        .timeline-event {
            position: relative;
            margin-bottom: 15px;
        }
        .timeline-event::before {
            content: '';
            position: absolute;
            left: -26px;
            top: 5px;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #3b82f6;
        }
        .timeline-event .time { font-size: 12px; color: #6b7280; font-family: monospace; }
        .timeline-event .text { font-size: 14px; font-weight: 500; }
        
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 30px;
            font-size: 14px;
        }
        th, td {
            padding: 12px 15px;
            border-bottom: 1px solid #e5e7eb;
            text-align: left;
        }
        th { background-color: #f9fafb; font-weight: 600; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>Aegis AI Security Report</h1>
            <div class="meta">
                <span>Execution ID: {{ execution_id }}</span>
                <span>Date: {{ date }}</span>
            </div>
        </div>

        <div class="summary-cards">
            <div class="card">
                <h3>Files Scanned</h3>
                <div class="value">{{ manifest.file_count }}</div>
            </div>
            <div class="card">
                <h3>Vulnerabilities</h3>
                <div class="value">{{ findings|length }}</div>
            </div>
            <div class="card threat">
                <h3>Threat Score</h3>
                <div class="value text-red-500">{{ threat_score }}</div>
            </div>
        </div>

        <h2>Repository Overview</h2>
        <table>
            <tr>
                <th>Framework</th>
                <td>{{ manifest.project_type }}</td>
            </tr>
            <tr>
                <th>Languages</th>
                <td>{{ manifest.languages_used.keys() | list | join(', ') }}</td>
            </tr>
            <tr>
                <th>Dependencies</th>
                <td>{{ manifest.dependency_managers | join(', ') }}</td>
            </tr>
        </table>

        <h2>Security Findings</h2>
        {% if findings %}
            {% for finding in findings %}
            <div class="finding">
                <div class="finding-header">
                    <h3>{{ finding.title }} <span style="font-weight:normal; color:#666; font-size:14px;">({{ finding.file_path }}:{{ finding.line_start }})</span></h3>
                    <span class="badge {{ finding.severity|lower }}">{{ finding.severity }}</span>
                </div>
                <div class="finding-body">
                    <p>{{ finding.description }}</p>
                    
                    {% if finding.code_snippet %}
                    <div class="code-snippet">{{ finding.code_snippet }}</div>
                    {% endif %}
                    
                    <p><strong>AI Reasoning:</strong> {{ finding.explanation }}</p>
                    
                    <div class="remediation">
                        <strong>Remediation:</strong> {{ finding.remediation_recommendation }}
                    </div>
                </div>
            </div>
            {% endfor %}
        {% else %}
            <p>No vulnerabilities detected.</p>
        {% endif %}

        <h2>Execution Timeline</h2>
        <div class="timeline">
            {% for event in timeline %}
            <div class="timeline-event">
                <div class="time">{{ event.timestamp }} - {{ event.agent_id }}</div>
                <div class="text">{{ event.message }}</div>
            </div>
            {% endfor %}
        </div>
    </div>
</body>
</html>
