# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# For local dev outside Docker: postgresql+asyncpg://sentinel:sentinel_dev@localhost:5432/sentinel_db
# For Docker Compose: postgresql+asyncpg://sentinel:sentinel_dev@postgres:5432/sentinel_db
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel_dev@localhost:5432/sentinel_db

# ── Redis ─────────────────────────────────────────────────────────────────────
# For local dev outside Docker: redis://localhost:6379/0
# For Docker Compose: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# ── Gemini API (used from Milestone 2 onward) ─────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_FAST=gemini-2.0-flash
GEMINI_MODEL_DEEP=gemini-1.5-pro

# ── Clerk Authentication ───────────────────────────────────────────────────────
# Obtain from https://dashboard.clerk.com → your application → API Keys
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Your Clerk instance JWKS URL.
# Format: https://<your-clerk-frontend-api>/.well-known/jwks.json
# Find your frontend API URL in Clerk dashboard → API Keys → Frontend API
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json

# ── Clerk (Frontend — Next.js) ────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── API URL (used by Next.js frontend) ────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── File Storage (local filesystem for MVP) ───────────────────────────────────
REPORT_OUTPUT_DIR=./generated_reports
UPLOAD_TEMP_DIR=./tmp/uploads

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list is NOT supported — use JSON array syntax for multiple origins
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_VERSION=0.1.0
